# Third-party datasets — NOT redistributed here (see README > Data to download them).
# We ignore their contents but keep the folder structure via a tracked .gitkeep.
data/metrica/*
!data/metrica/.gitkeep
data/statsbomb_360/*
!data/statsbomb_360/.gitkeep

# Derived / processed datasets — regenerated by the scripts, not committed.
data/processed/*
!data/processed/.gitkeep

# Large / regenerable model artifacts (>100 MB or experimental)
*rsf*.pkl
pass_model_randomforest.pkl
best_xg_model_randomforest.pkl

# Generated media
*.mp4
results/videos/
results/goal_threat_maps/action_visualizations/
